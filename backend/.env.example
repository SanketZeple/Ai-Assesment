# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/summarizer_db

# LLM API
LLM_API_KEY=your_openai_api_key_here
LLM_MODEL=gpt-3.5-turbo
LLM_MAX_TOKENS=1000
LLM_TEMPERATURE=0.3

# File Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760  # 10MB in bytes

# Retry Settings
MAX_RETRIES=2
RETRY_DELAY=1

# Application
DEBUG=True

# Redis
REDIS_URL=redis://localhost:6379/0

# Frontend
VITE_API_BASE_URL=http://localhost:8000